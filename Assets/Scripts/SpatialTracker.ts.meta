      {}
  InputLines:
    - '// @input SceneObject boardVisuals {"hint":"Object whose enabled-state flips true once the board is placed (VisualParent)."}'
    - '// @input SceneObject boardRoot {"hint":"Root object positioned/rotated on the ground when placed (Example Surface)."}'
    - "// @input SceneObject camera {\"hint\":\"The camera / head object used as the user's position (Camera Object).\"}"
    - '// @input string backendUrl = "http://localhost:3000" {"hint":"Backend base URL, e.g. http://192.168.1.20:3000 (device) or http://localhost:3000 (preview)."}'
    - '// @input float sendIntervalSeconds = 1 {"hint":"How often (seconds) to send the position."}'
    - '// @input float boardWidthMeters = 2 {"hint":"Game board width in meters (local X). Must match the physical border."}'
    - '// @input float boardHeightMeters = 2 {"hint":"Game board depth in meters (local Z). Must match the physical border."}'
    - "// @input SceneObject waypointsParent {\"hint\":\"Parent object holding the numbered box objects (the 'Waypoints' container). The game uses the first Max Number of its children.\"}"
    - '// @input Asset.Material baseTileMaterial {"hint":"Unlit material used to color the boxes (WaypointUnlit). Its baseColor is tinted per box."}'
    - '// @input bool enableHeartRate = true {"hint":"Connect to a Bluetooth heart-rate monitor (e.g. Garmin in Broadcast HR mode) and send BPM with each position. In Lens Studio Preview, mock BPM is sent instead."}'
    - "// @input string hrDeviceName {\"hint\":\"Optional Bluetooth device-name filter (your Garmin's broadcast name). Leave empty to accept the first heart-rate device found.\"}"
    - '// @input Asset.BluetoothCentralModule bluetoothModule {"hint":"(Optional) Bluetooth Central Module asset. If assigned it is used instead of the built-in module - add one via the Asset Browser only if the built-in require fails on your device."}'
    - '// @input float plateCount = 9 {"hint":"Total plates to place on the board (1..pool size)."}'
    - '// @input float sequenceLength = 5 {"hint":"How many plates form the sequence the user must recall (<= Plate Count)."}'
    - '// @input float observeDelaySeconds = 4 {"hint":"Seconds to wait after placement (observe the board) before the sequence is shown."}'
    - '// @input float repeatObserveDelaySeconds = 10 {"hint":"Seconds to step back / observe before a REPEAT test (after finishing and leaving the board)."}'
    - '// @input float highlightSeconds = 2 {"hint":"Seconds each plate stays highlighted (orange) while the sequence is demonstrated."}'
    - '// @input float tileSizeMeters = 0.3 {"hint":"Tile size in meters (edge length of each plate)."}'
    - '// @input float reachRadiusMeters = 0.4 {"hint":"How close (meters) the player must get to a box to count as reached."}'
    - "// @input float minSpacingMeters = 0.6 {\"hint\":\"Minimum spacing between box centers in meters (so they don't overlap).\"}"
    - '// @input Asset.AudioTrackAsset enterSound {"hint":"Sound played when the user steps into the board (enter)."}'
    - '// @input Asset.AudioTrackAsset reachSound1 {"hint":"Reach sound option 1 - one of the three plays at random each time a number is reached."}'
    - '// @input Asset.AudioTrackAsset reachSound2 {"hint":"Reach sound option 2 - one of the three plays at random each time a number is reached."}'
    - '// @input Asset.AudioTrackAsset reachSound3 {"hint":"Reach sound option 3 - one of the three plays at random each time a number is reached."}'
    - '// @input Asset.AudioTrackAsset endSound {"hint":"Sound played when the final number is reached (end) - different from the reach sounds."}'
    - '// @input Component.Text timerText {"hint":"HUD Text that shows the run timer (TimerText under the Camera)."}'
    - '// @input Component.Text overlayText {"hint":"HUD Text used for instructions/overlays (OverlayText under the Camera)."}'
    - '// @input Component.Text heartText {"hint":"HUD Text showing the live heart rate, above the timer (HeartText under the Camera)."}'
    - '// @input Asset.Texture timerIcon {"hint":"Icon image shown to the left of the timer."}'
    - '// @input Asset.Texture heartIcon {"hint":"Icon image shown to the left of the heart rate."}'
    - '// @input SceneObject timerIconObject {"hint":"Plane object that displays the timer icon (TimerIcon under the Camera)."}'
    - '// @input SceneObject heartIconObject {"hint":"Plane object that displays the heart-rate icon (HeartIcon under the Camera)."}'
    - '// @input Asset.Material iconMaterial {"hint":"Unlit material used to render the HUD icons (IconUnlit)."}'
    - '// @input Asset.Material borderMaterial {"hint":"Board border material (BorderLit) - tinted blue at runtime to match the web app."}'
